{
  "name": "@willow-ds/tokens",
  "author": "Josh Bowden",
  "version": "1.0.0",
  "description": "Willow design system tokens",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsx build/index.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset tag",
    "changeset:check": "node scripts/changeset-required.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./css": "./dist/tokens.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoshBowdenConcepts/willow-ds.git"
  },
  "keywords": [],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JoshBowdenConcepts/willow-ds/issues"
  },
  "homepage": "https://github.com/JoshBowdenConcepts/willow-ds#readme",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.28.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
