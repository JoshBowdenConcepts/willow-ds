#!/usr/bin/env sh
# Block pushing changes that alter the published export without a changeset.
# The decision (build + pack HEAD vs the base branch, then compare) lives in
# scripts/changeset-required.mjs so it is maintained in one place (shared with
# CI). The build + pnpm pack run automatically from here; no manual steps.

# Compare against the local tip of the base branch when it exists, otherwise
# fall back to the remote-tracking ref.
if git show-ref --verify --quiet refs/remotes/origin/main; then
  BASE_REF="origin/main"
else
  BASE_REF="main"
fi

node scripts/changeset-required.mjs "$BASE_REF"
